{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skycomet",
  "version": "0.1.0-alpha.1",
  "identifier": "com.skycomet.app",
  "build": {
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../frontend"
    },
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../frontend"
    },
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "splash",
        "title": "Skycomet",
        "url": "splash.html",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "fullscreen": false,
        "decorations": false,
        "visible": false,
        "backgroundColor": [246, 245, 242, 0]
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "resources": [
      "resources/catalog-snapshot.json"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg2MTdCMkY5NDQxN0U4OTcKUldTWDZCZEUrYklYaHJtS2lqQStqck85aHFKYUJQMGp6RkNuZlVQdzlVeTR5bUR4VTJ0bW5uV3gK",
      "endpoints": [
        "https://github.com/oguzkabaca/SkyComet/releases/latest/download/latest.json"
      ]
    }
  }
}
