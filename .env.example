# SkyComet — development environment variables
# Copy this file to .env. The .env file itself is gitignored.

# Log level: trace, debug, info, warn, error
RUST_LOG=skycomet=debug,tower=warn,reqwest=warn

# Vite dev server port (Tauri connects to this)
VITE_PORT=5173

# Development DB path override (default: ./dev-data/skycomet.db)
# SKYCOMET_DB_PATH=./dev-data/custom.db

# CelesTrak base URL (can be overridden for test mocking)
# CELESTRAK_BASE_URL=https://celestrak.org

# SatNOGS base URL
# SATNOGS_BASE_URL=https://db.satnogs.org
